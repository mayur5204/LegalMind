# Ollama
OLLAMA_BASE=http://127.0.0.1:11434
CHAT_MODEL=gemma4:31b-cloud

# CORS — comma-separated list of allowed frontend origins
# In production set this to your domain, e.g. https://legalmind.yourdomain.com
# When Nginx serves both frontend and API on the same domain, CORS is not
# strictly required, but keep it set to your domain for safety.
ALLOWED_ORIGINS=http://localhost:5173
