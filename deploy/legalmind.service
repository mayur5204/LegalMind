[Unit]
Description=LegalMind FastAPI backend
After=network.target ollama.service
Wants=ollama.service

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/legalmind
EnvironmentFile=/home/ubuntu/legalmind/.env
ExecStart=/home/ubuntu/legalmind/venv/bin/uvicorn backend.main:app \
    --host 127.0.0.1 \
    --port 8000 \
    --workers 2 \
    --log-level info
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
